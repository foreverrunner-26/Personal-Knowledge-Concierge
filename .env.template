# Personal Knowledge Concierge — Environment Variables
# ⚠️ SECURITY: Copy this file to .env and fill in your keys.
# .env is gitignored — NEVER commit real API keys.

# ── LLM API Configuration (required for live agent mode) ──────────────────
API_KEY=sk-your-api-key

# API base URL
BASE_URL=https://api.deepseek.com

# Model name
MODEL=deepseek-chat

# Optional: GitHub token for higher rate limits on repo analysis
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# Demo mode (set to "false" to use live API calls)
DEMO_MODE=true

# Memory store path (default: ./memory/memory.json)
MEMORY_STORE_PATH=./memory/memory.json

# Maximum articles to fetch per briefing
MAX_ARTICLES_PER_BRIEFING=20
